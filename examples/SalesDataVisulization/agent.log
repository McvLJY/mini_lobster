def fix_bad_rows(row):
    """修复格式错误的数据行"""
    if pd.isna(row['产品类别']) and isinstance(row['日期'], str) and '\    ' in row['日期']:
        # 这是一个格式错误的行，需要解析
        parts = row['日期'].split('\    ')
        if len(parts) >= 5:
            return pd.Series({
                '日期': parts[0],
                '产品类别': parts[1],
                '产品名称': parts[2],
                '销售额': float(parts[3]) if parts[3] else np.nan,
                '数量': float(parts[4]) if parts[4] else np.nan
            })
    return row

# 应用修复
print("
修复格式错误的数据行...")
fixed_rows = []
for idx, row in df.iterrows():
    if pd.isna(row['产品类别']) and isinstance(row['日期'], str) and '\    ' in row['日期']:
        fixed_row = fix_bad_rows(row)
        fixed_rows.append((idx, fixed_row))

print(f"找到 {len(fixed_rows)} 个需要修复的行")

# 创建修复后的DataFrame
df_fixed = df.copy()
for idx, fixed_row in fixed_rows:
    df_fixed.loc[idx] = fixed_row

print("修复后数据形状:", df_fixed.shape)

# 再次检查缺失值
print("
修复后缺失值统计:")
