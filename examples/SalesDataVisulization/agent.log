import pandas as pd
import os
import re
from io import StringIO

def detect_separator(file_path):
    """检测文件的分隔符"""
    with open(file_path, 'r', encoding='utf-8') as f:
        first_line = f.readline().strip()
    
    # 常见分隔符及其在第一行出现的次数
    separators = [',', '    ', ';', '|']
    sep_counts = {}
    
    for sep in separators:
        count = first_line.count(sep)
        if count > 0:
            sep_counts[sep] = count
    
    if not sep_counts:
        # 如果没有找到常见分隔符，尝试空格
        if ' ' in first_line:
            return ' '
        return None
    
    # 返回出现次数最多的分隔符
    return max(sep_counts.items(), key=lambda x: x[1])[0]

def read_sales_file(file_path):
    """读取销售数据文件，自动检测分隔符"""
    print(f"读取文件: {file_path}")
    
    # 检测分隔符
    sep = detect_separator(file_path)
    print(f"  检测到的分隔符: {repr(sep)}")
    
    try:
        # 尝试用检测到的分隔符读取
        if sep:
            df = pd.read_csv(file_path, sep=sep, encoding='utf-8')
        else:
            # 如果没有检测到分隔符，尝试自动检测
            df = pd.read_csv(file_path, encoding='utf-8', sep=None, engine='python')
        
        print(f"  成功读取，数据形状: {df.shape}")
        return df
        
    except Exception as e:
        print(f"  读取失败: {e}")
        # 尝试其他方法
        try:
            # 读取原始内容
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
            
            # 尝试替换不同的分隔符为逗号
            for test_sep in [',', '    ', ';', '|']:
                if test_sep in content:
                    # 替换为逗号
                    normalized_content = content.replace(test_sep, ',')
                    df = pd.read_csv(StringIO(normalized_content), encoding='utf-8')
                    print(f"  使用替换方法成功读取，数据形状: {df.shape}")
                    return df
            
            # 如果都不行，尝试正则表达式分割
            lines = content.strip().split('
')
            data = []
            for line in lines:
                # 尝试用多种分隔符分割
                parts = re.split(r'[,;    |]', line)
                if len(parts) >= 5:  # 应该有5列
                    data.append(parts[:5])  # 只取前5列
            
            if data:
                df = pd.DataFrame(data[1:], columns=data[0])
                print(f"  使用正则表达式成功读取，数据形状: {df.shape}")
                return df
                
        except Exception as e2:
            print(f"  所有读取方法都失败: {e2}")
            return None

# 读取所有文件
all_data = []
files = [
    "sales_data/sales_2023_01.tsv",
    "sales_data/sales_2023_02.tsv", 
    "sales_data/sales_2023_03.txt",
    "sales_data/sales_2023_error.txt"
]

for file_path in files:
    df = read_sales_file(file_path)
    if df is not None:
        # 确保列名一致
        expected_columns = ['日期', '产品类别', '产品名称', '销售额', '数量']
        if set(df.columns) != set(expected_columns):
            print(f"  列名不匹配，实际列: {list(df.columns)}")
            # 尝试重命名列
            if len(df.columns) == len(expected_columns):
                df.columns = expected_columns
                print(f"  已重命名列")
        
        all_data.append(df)

# 合并所有数据
if all_data:
    combined_df = pd.concat(all_data, ignore_index=True)
    print(f"
合并后的数据形状: {combined_df.shape}")
    print(f"列名: {list(combined_df.columns)}")
    
    # 显示数据概览
    print("
数据概览:")
    print(combined_df.head())
    print(f"
数据类型:")
    print(combined_df.dtypes)
    
    # 检查缺失值
    print(f"
缺失值统计:")
    print(combined_df.isnull().sum())
    
    # 保存合并后的数据
    combined_df.to_csv("combined_sales_data.csv", index=False, encoding='utf-8')
    print(f"
