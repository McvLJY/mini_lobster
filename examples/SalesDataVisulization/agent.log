# 删除仍然存在的缺失值
df_clean = df_fixed.dropna()
print(f"最终清理后数据形状: {df_clean.shape}")

# 确保日期格式正确
df_clean['日期'] = pd.to_datetime(df_clean['日期'], errors='coerce')
df_clean = df_clean.dropna(subset=['日期'])
print(f"日期转换后数据形状: {df_clean.shape}")

# 提取月份信息
df_clean['月份'] = df_clean['日期'].dt.to_period('M')
df_clean['月份_str'] = df_clean['月份'].astype(str)

# 按月份和产品类别汇总销售量
monthly_sales = df_clean.groupby(['月份_str', '产品类别'])['数量'].sum().reset_index()

# 创建完整的时间序列（确保所有月份都有数据）
all_months = sorted(df_clean['月份_str'].unique())
all_categories = sorted(df_clean['产品类别'].unique())

# 创建完整的数据框架
full_data = []
for month in all_months:
    for category in all_categories:
        full_data.append({'月份_str': month, '产品类别': category})

full_df = pd.DataFrame(full_data)

# 合并实际数据
monthly_sales_complete = pd.merge(full_df, monthly_sales, 
                                   on=['月份_str', '产品类别'], 
                                   how='left').fillna(0)

print("
完整按月销售量数据:")
