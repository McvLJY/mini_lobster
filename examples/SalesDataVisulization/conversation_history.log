      "arguments": "{\"purpose\": \"智能读取所有数据文件并合并数据\", \"code\": \"import pandas as pd\\nimport os\\nimport re\\nfrom io import StringIO\\n\\ndef detect_separator(file_path):\\n    \\\"\\\"\\\"检测文件的分隔符\\\"\\\"\\\"\\n    with open(file_path, 'r', encoding='utf-8') as f:\\n        first_line = f.readline().strip()\\n    \\n    # 常见分隔符及其在第一行出现的次数\\n    separators = [',', '\\\\t', ';', '|']\\n    sep_counts = {}\\n    \\n    for sep in separators:\\n        count = first_line.count(sep)\\n        if count > 0:\\n            sep_counts[sep] = count\\n    \\n    if not sep_counts:\\n        # 如果没有找到常见分隔符，尝试空格\\n        if ' ' in first_line:\\n            return ' '\\n        return None\\n    \\n    # 返回出现次数最多的分隔符\\n    return max(sep_counts.items(), key=lambda x: x[1])[0]\\n\\ndef read_sales_file(file_path):\\n    \\\"\\\"\\\"读取销售数据文件，自动检测分隔符\\\"\\\"\\\"\\n    print(f\\\"读取文件: {file_path}\\\")\\n    \\n    # 检测分隔符\\n    sep = detect_separator(file_path)\\n    print(f\\\"  检测到的分隔符: {repr(sep)}\\\")\\n    \\n    try:\\n        # 尝试用检测到的分隔符读取\\n        if sep:\\n            df = pd.read_csv(file_path, sep=sep, encoding='utf-8')\\n        else:\\n            # 如果没有检测到分隔符，尝试自动检测\\n            df = pd.read_csv(file_path, encoding='utf-8', sep=None, engine='python')\\n        \\n        print(f\\\"  成功读取，数据形状: {df.shape}\\\")\\n        return df\\n        \\n    except Exception as e:\\n        print(f\\\"  读取失败: {e}\\\")\\n        # 尝试其他方法\\n        try:\\n            # 读取原始内容\\n            with open(file_path, 'r', encoding='utf-8') as f:\\n                content = f.read()\\n            \\n            # 尝试替换不同的分隔符为逗号\\n            for test_sep in [',', '\\\\t', ';', '|']:\\n                if test_sep in content:\\n                    # 替换为逗号\\n                    normalized_content = content.replace(test_sep, ',')\\n                    df = pd.read_csv(StringIO(normalized_content), encoding='utf-8')\\n                    print(f\\\"  使用替换方法成功读取，数据形状: {df.shape}\\\")\\n                    return df\\n            \\n            # 如果都不行，尝试正则表达式分割\\n            lines = content.strip().split('\\\\n')\\n            data = []\\n            for line in lines:\\n                # 尝试用多种分隔符分割\\n                parts = re.split(r'[,;\\\\t|]', line)\\n                if len(parts) >= 5:  # 应该有5列\\n                    data.append(parts[:5])  # 只取前5列\\n            \\n            if data:\\n                df = pd.DataFrame(data[1:], columns=data[0])\\n                print(f\\\"  使用正则表达式成功读取，数据形状: {df.shape}\\\")\\n                return df\\n                \\n        except Exception as e2:\\n            print(f\\\"  所有读取方法都失败: {e2}\\\")\\n            return None\\n\\n# 读取所有文件\\nall_data = []\\nfiles = [\\n    \\\"sales_data/sales_2023_01.tsv\\\",\\n    \\\"sales_data/sales_2023_02.tsv\\\", \\n    \\\"sales_data/sales_2023_03.txt\\\",\\n    \\\"sales_data/sales_2023_error.txt\\\"\\n]\\n\\nfor file_path in files:\\n    df = read_sales_file(file_path)\\n    if df is not None:\\n        # 确保列名一致\\n        expected_columns = ['日期', '产品类别', '产品名称', '销售额', '数量']\\n        if set(df.columns) != set(expected_columns):\\n            print(f\\\"  列名不匹配，实际列: {list(df.columns)}\\\")\\n            # 尝试重命名列\\n            if len(df.columns) == len(expected_columns):\\n                df.columns = expected_columns\\n                print(f\\\"  已重命名列\\\")\\n        \\n        all_data.append(df)\\n\\n# 合并所有数据\\nif all_data:\\n    combined_df = pd.concat(all_data, ignore_index=True)\\n    print(f\\\"\\\\n合并后的数据形状: {combined_df.shape}\\\")\\n    print(f\\\"列名: {list(combined_df.columns)}\\\")\\n    \\n    # 显示数据概览\\n    print(\\\"\\\\n数据概览:\\\")\\n    print(combined_df.head())\\n    print(f\\\"\\\\n数据类型:\\\")\\n    print(combined_df.dtypes)\\n    \\n    # 检查缺失值\\n    print(f\\\"\\\\n缺失值统计:\\\")\\n    print(combined_df.isnull().sum())\\n    \\n    # 保存合并后的数据\\n    combined_df.to_csv(\\\"combined_sales_data.csv\\\", index=False, encoding='utf-8')\\n    print(f\\\"\\