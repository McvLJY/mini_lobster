matplotlib.rcParams['axes.unicode_minus'] = False\\n        return False\\n\\n# 设置中文字体\\nsetup_chinese_font_improved()\\n\\n# 加载数据\\ndf = pd.read_csv(\\\"final_combined_sales.csv\\\", encoding='utf-8')\\ndf['日期'] = pd.to_datetime(df['日期'])\\ndf['月份'] = df['日期'].dt.to_period('M')\\ndf['月份_str'] = df['月份'].astype(str)\\n\\n# 按月份和产品类别汇总销售量\\nmonthly_sales = df.groupby(['月份_str', '产品类别'])['数量'].sum().reset_index()\\n\\n# 创建透视表\\npivot_table = monthly_sales.pivot(index='月份_str', columns='产品类别', values='数量').fillna(0)\\npivot_table = pivot_table.reindex(sorted(pivot_table.index))\\n\\n# 创建更美观的折线图\\nplt.figure(figsize=(16, 9))\\n\\n# 设置颜色方案\\ncolors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\\nmarkers = ['o', 's', '^', 'D', 'v']\\nline_styles = ['-', '--', '-.', ':', '-']\\n\\n# 为每个产品类别绘制折线\\nfor i, category in enumerate(pivot_table.columns):\\n    plt.plot(pivot_table.index, pivot_table[category], \\n            label=category, \\n            color=colors[i % len(colors)],\\n            marker=markers[i % len(markers)],\\n            linestyle=line_styles[i % len(line_styles)],\\n            linewidth=3,\\n            markersize=10,\\n            markeredgewidth=2,\\n            markeredgecolor='white')\\n\\n# 设置图表属性\\nplt.title('2023年各商品类别按月销售量趋势分析', \\n          fontsize=22, fontweight='bold', pad=25, \\n          fontproperties={'family': 'sans-serif', 'weight': 'bold'})\\n\\nplt.xlabel('月份', fontsize=16, fontweight='bold')\\nplt.ylabel('销售量（件）', fontsize=16, fontweight='bold')\\n\\n# 设置图例\\nlegend = plt.legend(title='商品类别', title_fontsize=14, fontsize=12, \\n                   loc='upper left', frameon=True, framealpha=0.9,\\n                   edgecolor='gray', facecolor='white')\\nlegend.get_title().set_fontweight('bold')\\n\\n# 设置网格\\nplt.grid(True, alpha=0.2, linestyle='-', linewidth=0.5)\\n\\n# 设置x轴刻度\\nplt.xticks(rotation=45, ha='right', fontsize=12)\\nplt.yticks(fontsize=12)\\n\\n# 设置坐标轴范围\\nplt.ylim(bottom=0, top=pivot_table.values.max() * 1.1)\\n\\n# 添加数据标签（选择性显示）\\nfor i, category in enumerate(pivot_table.columns):\\n    for j, month in enumerate(pivot_table.index):\\n        value = pivot_table[category].iloc[j]\\n        if value > 0 and j % 3 == 0:  # 每3个月显示一次标签\\n            plt.text(j, value + 8, f'{int(value)}', \\n                    ha='center', va='bottom', \\n                    fontsize=10, fontweight='bold',\\n                    color=colors[i % len(colors)],\\n                    bbox=dict(boxstyle='round,pad=0.3', \\n                             facecolor='white', \\n                             edgecolor=colors[i % len(colors)], \\n                             alpha=0.8))\\n\\n# 添加背景色区分季度\\nquarters = [0, 3, 6, 9, 12]\\nquarter_colors = ['#f0f8ff', '#fff0f5', '#f0fff0', '#fffaf0']\\nfor i in range(len(quarters)-1):\\n    plt.axvspan(quarters[i]-0.5, quarters[i+1]-0.5, \\n                alpha=0.1, color=quarter_colors[i % len(quarter_colors)])\\n\\n# 添加季度标签\\nquarter_labels = ['Q1', 'Q2', 'Q3', 'Q4']\\nfor i in range(len(quarter_labels)):\\n    x_pos = quarters[i] + 1.5\\n    plt.text(x_pos, plt.ylim()[1] * 0.95, quarter_labels[i],\\n             ha='center', va='top', fontsize=11, fontweight='bold',\\n             bbox=dict(boxstyle='round,pad=0.3', facecolor='white', edgecolor='gray'))\\n\\n# 调整布局\\nplt.tight_layout()\\n\\n# 保存高质量图表\\noutput_file = \\\"monthly_sales_by_category_final.png\\\"\\nplt.savefig(output_file, dpi=300, bbox_inches='tight', facecolor='white', edgecolor='none')\\nprint(f\\\"改进版折线图已保存到: {output_file}\\\")\\n\\n# 显示图表\\nplt.show()\\n\\n# 创建数据汇总表\\nprint(\\\"\\\\n2023年各商品类别销售量汇总:\\\")\\nprint(\\\"=\\\" * 60)\\nfor category in pivot_table.columns:\\n    total_sales = pivot_table[category].sum()\\n    avg_sales = pivot_table[category].mean()\\n    max_month = pivot_table[category].idxmax()\\n    max_sales = pivot_table[category].max()\\n    \\n    print(f\\\"{category}:\\\")\\n    print(f\\\"  总销售量: {int(total_sales):,} 件\\\")\\n    print(f\\\"  月平均: {avg_sales:.1f} 件\\\")\\n    print(f\\\"  最高月份: {max_month} ({int(max_sales)} 件)\\\")\\n    print()\\n\\n# 保存详细报告\\nwith open(\\\"sales_analysis_report.txt\\\", \\\"w\\\", encoding='utf-8') as f:\\n    f.write(\\\"2023年销售数据分析报告\\\\n\\\")\\n    f.write(\\\"=\\\" * 50 + \\\"\\\\n\\\\n\\\")\\n    f.write(\\\"数据来源: sales_data目录下的4个文件\\\\n\\\")\\n    f.write(\\\"数据记录总数: \\\" + str(len(df)) + \\\"\\\\n\\\")\\n    f.write(\\\"分析时间范围: 2023年1月 - 2023年12月\\\\n\\\")\\n    f.write(\\\"商品类别数量: \\\" + str(len(pivot_table.columns)) + \\\"\\\\n\\\\n\\\")\\n    \\n    f.write(\\\"各商品类别年度销售汇总:\\\\n\\\")\\n    f.write(\\\"-\\\" * 40 + \\\"\\\\n\\\")\\n    for category in pivot_table.columns:\\n        total_sales = pivot_table[category].sum()\\n        f.write(f\\\"{category}: {int(total_sales):,} 件\\\\n\\\")\\n    \\n    f.write(\\\"\\\\n图表文件:\\\\n\\\")\\n    f.write(f\\\"- 折线图: {output_file}\\\\n\\\")\\n    f.write(f\\\"- 汇总数据: monthly_sales_summary.csv\\\\n\\\")\\n    f.write(f\\\"- 原始数据: final_combined_sales.csv\\\\n\\\")\\n\\nprint(f\\\"分析报告已保存到: sales_analysis_report.txt\\\")\\nprint(\\\"\\\\n所有任务完成！\\\")\"}"
