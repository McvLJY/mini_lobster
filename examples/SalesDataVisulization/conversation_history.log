      "arguments": "{\"purpose\": \"处理数据并生成按月销售量的折线图\", \"code\": \"import pandas as pd\\nimport numpy as np\\nimport matplotlib.pyplot as plt\\nimport matplotlib\\nfrom matplotlib import font_manager\\nimport os\\n\\n# 设置中文字体\\ndef setup_chinese_font():\\n    \\\"\\\"\\\"设置中文字体支持\\\"\\\"\\\"\\n    try:\\n        # 尝试使用系统中文字体\\n        font_paths = [\\n            '/System/Library/Fonts/PingFang.ttc',  # macOS\\n            '/usr/share/fonts/truetype/wqy/wqy-microhei.ttc',  # Linux\\n            'C:/Windows/Fonts/simhei.ttf',  # Windows\\n            'C:/Windows/Fonts/msyh.ttc',  # Windows\\n        ]\\n        \\n        for font_path in font_paths:\\n            if os.path.exists(font_path):\\n                font_prop = font_manager.FontProperties(fname=font_path)\\n                matplotlib.rcParams['font.sans-serif'] = [font_prop.get_name()]\\n                matplotlib.rcParams['axes.unicode_minus'] = False\\n                print(f\\\"使用字体: {font_path}\\\")\\n                return True\\n        \\n        # 如果找不到系统字体，使用默认设置\\n        matplotlib.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\\n        matplotlib.rcParams['axes.unicode_minus'] = False\\n        print(\\\"使用默认中文字体设置\\\")\\n        return True\\n        \\n    except Exception as e:\\n        print(f\\\"字体设置失败: {e}\\\")\\n        return False\\n\\n# 设置中文字体\\nsetup_chinese_font()\\n\\n# 加载数据\\ndf = pd.read_csv(\\\"final_combined_sales.csv\\\", encoding='utf-8')\\nprint(\\\"数据形状:\\\", df.shape)\\nprint(\\\"\\\\n数据前5行:\\\")\\nprint(df.head())\\n\\n# 确保数据类型正确\\ndf['日期'] = pd.to_datetime(df['日期'], errors='coerce')\\ndf['销售额'] = pd.to_numeric(df['销售额'], errors='coerce')\\ndf['数量'] = pd.to_numeric(df['数量'], errors='coerce')\\n\\n# 检查数据\\nprint(\\\"\\\\n数据类型:\\\")\\nprint(df.dtypes)\\nprint(\\\"\\\\n缺失值统计:\\\")\\nprint(df.isnull().sum())\\n\\n# 提取月份信息\\ndf['月份'] = df['日期'].dt.to_period('M')\\ndf['月份_str'] = df['月份'].astype(str)\\n\\n# 按月份和产品类别汇总销售量\\nmonthly_sales = df.groupby(['月份_str', '产品类别'])['数量'].sum().reset_index()\\n\\n# 创建完整的时间序列\\nall_months = sorted(df['月份_str'].unique())\\nall_categories = sorted(df['产品类别'].unique())\\n\\nprint(f\\\"\\\\n所有月份: {all_months}\\\")\\nprint(f\\\"所有产品类别: {all_categories}\\\")\\n\\n# 创建透视表用于绘图\\npivot_table = monthly_sales.pivot(index='月份_str', columns='产品类别', values='数量').fillna(0)\\n\\nprint(\\\"\\\\n透视表形状:\\\", pivot_table.shape)\\nprint(\\\"\\\\n透视表数据:\\\")\\nprint(pivot_table)\\n\\n# 确保月份顺序正确\\npivot_table = pivot_table.reindex(sorted(pivot_table.index))\\n\\n# 生成折线图\\nplt.figure(figsize=(14, 8))\\n\\n# 为每个产品类别绘制折线\\ncolors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\\nmarkers = ['o', 's', '^', 'D', 'v']\\n\\nfor i, category in enumerate(all_categories):\\n    if category in pivot_table.columns:\\n        plt.plot(pivot_table.index, pivot_table[category], \\n                label=category, \\n                color=colors[i % len(colors)],\\n                marker=markers[i % len(markers)],\\n                linewidth=2.5,\\n                markersize=8)\\n\\n# 设置图表属性\\nplt.title('2023年各商品类别按月销售量趋势', fontsize=18, fontweight='bold', pad=20)\\nplt.xlabel('月份', fontsize=14)\\nplt.ylabel('销售量', fontsize=14)\\nplt.legend(title='商品类别', title_fontsize=12, fontsize=11, loc='upper left')\\nplt.grid(True, alpha=0.3, linestyle='--')\\n\\n# 设置x轴刻度\\nplt.xticks(rotation=45, ha='right')\\n\\n# 添加数据标签（每隔一个月显示）\\nfor i, category in enumerate(all_categories):\\n    if category in pivot_table.columns:\\n        for j, month in enumerate(pivot_table.index):\\n            if j % 2 == 0:  # 每隔一个月显示标签\\n                value = pivot_table[category].iloc[j]\\n                if value > 0:  # 只显示非零值\\n                    plt.text(j, value + 5, f'{int(value)}', \\n                            ha='center', va='bottom', \\n                            fontsize=9, color=colors[i % len(colors)])\\n\\n# 调整布局\\nplt.tight_layout()\\n\\n# 保存图表\\noutput_file = \\\"monthly_sales_by_category.png\\\"\\nplt.savefig(output_file, dpi=300, bbox_inches='tight')\\nprint(f\\\"\\\\n折线图已保存到: {output_file}\\\")\\n\\n# 显示图表\\nplt.show()\\n\\n# 创建第二个图表：堆叠面积图\\nplt.figure(figsize=(14, 8))\\n\\n# 创建堆叠面积图\\nplt.stackplot(pivot_table.index, \\n              [pivot_table[cat] for cat in all_categories if cat in pivot_table.columns],\\n              labels=[cat for cat in all_categories if cat in pivot_table.columns],\\n              colors=colors[:len(all_categories)],\\n              alpha=0.7)\\n\\nplt.title('2023年各商品类别按月销售量堆叠图', fontsize=18, fontweight='bold', pad=20)\\nplt.xlabel('月份', fontsize=14)\\nplt.ylabel('销售量', fontsize=14)\\nplt.legend(title='商品类别', title_fontsize=12, fontsize=11, loc='upper left')\\nplt.grid(True, alpha=0.3, linestyle='--')\\nplt.xticks(rotation=45, ha='right')\\n\\nplt.tight_layout()\\n\\n# 保存第二个图表\\noutput_file2 = \\\"monthly_sales_stacked.png\\\"\\nplt.savefig(output_file2, dpi=300, bbox_inches='tight')\\nprint(f\\\"堆叠图已保存到: {output_file2}\\\")\\n\\nplt.show()\\n\\n# 保存汇总数据\\nsummary_file = \\\"monthly_sales_summary.csv\\\"\\npivot_table.to_csv(summary_file, encoding='utf-8')\\nprint(f\\\"汇总数据已保存到: {summary_file}\\\")\\n\\nprint(\\\"\\\\n图表生成完成！\\\")\"}"
